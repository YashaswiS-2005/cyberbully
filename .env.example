# Instagram API (optional)
INSTAGRAM_ACCESS_TOKEN=

# Database configuration (optional, for large-scale storage)
DATABASE_URL=postgresql://user:password@localhost:5432/cyberbully

# Redis configuration (optional, for async processing)
REDIS_URL=redis://localhost:6379/0